<?xml version="1.0" encoding="utf-8"?>
<!-- Example: two steering axles - primary (tracks path) and subordinate (inverse). -->
<vehicle name="Example multi-steer" version="1.0">
  <metadata>
    <source>pySweptPath example</source>
    <units>metres</units>
  </metadata>
  <steering_groups>
    <group id="0" role="primary"/>
    <group id="1" role="subordinate" ref="0" inverse="true"/>
  </steering_groups>
  <body>
    <width>2.5</width>
    <front_longitudinal>1.2</front_longitudinal>
    <rear_longitudinal>-5.0</rear_longitudinal>
  </body>
  <axles>
    <axle index="0">
      <longitudinal_pos>0.0</longitudinal_pos>
      <is_steering>true</is_steering>
      <steering_group>0</steering_group>
      <track_width>2.05</track_width>
      <tyre_width>0.35</tyre_width>
      <max_steer_angle_deg>42.0</max_steer_angle_deg>
    </axle>
    <axle index="1">
      <longitudinal_pos>-2.5</longitudinal_pos>
      <is_steering>true</is_steering>
      <steering_group>1</steering_group>
      <track_width>2.05</track_width>
      <tyre_width>0.35</tyre_width>
      <max_steer_angle_deg>25.0</max_steer_angle_deg>
    </axle>
    <axle index="2">
      <longitudinal_pos>-5.0</longitudinal_pos>
      <is_steering>false</is_steering>
      <track_width>2.05</track_width>
      <tyre_width>0.35</tyre_width>
    </axle>
  </axles>
</vehicle>
